# Provider: mock | live
NEXON_PROVIDER=mock

# Server-only. Required only when NEXON_PROVIDER=live.
NEXON_OPEN_API_KEY=
NEXON_BASE_URL=https://open.api.nexon.com/maplestory/v1
NEXON_REQUEST_TIMEOUT_MS=8000

# PostgreSQL. Example matches the recommended Docker Compose setup.
DATABASE_URL=postgresql://meyukbu:meyukbu@localhost:5432/meyukbu?schema=public

# Storage: memory (default mock/demo) | prisma (PostgreSQL persistence).
# Production must use prisma.
MEYUKBU_STORAGE=memory

# Canonical public origin used by QR codes and share images.
APP_ORIGIN=http://localhost:3000

# Use the user-authorized Maple Trackers boss artwork source. Set false for fully offline runs.
MEYUKBU_EXTERNAL_ART=true

# Freshness policy.
PROFILE_FRESH_HOURS=24
PROFILE_PUBLIC_EXPIRY_DAYS=30

# Use a long random value in production for application-level hashing/pepper.
APP_SECRET=replace-with-a-long-random-secret

# Reverse proxy/IP rate limiting. "vercel" is the production default and only
# reads forwarding headers that Vercel has stamped. For Cloudflare's extra
# shared-secret boundary, follow docs/CLOUDFLARE_RUNBOOK.md.
TRUSTED_PROXY_MODE=vercel
CLOUDFLARE_PROXY_SHARED_SECRET=

# Optional observability. The app must work without it.
SENTRY_DSN=
