generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// The provider that produced an immutable profile snapshot.
enum SnapshotProvider {
  MOCK
  NEXON_OPEN_API
}

/// Freshness is persisted with a snapshot so a version can be rendered consistently.
enum SnapshotFreshness {
  FRESH
  STALE
  EXPIRED
}

/// Every displayed datum is labelled with one of these sources in the application layer.
enum DataProvenance {
  NEXON_API
  SERVICE_CALCULATED
  USER_PROVIDED
  SERVICE_OBSERVED
}

enum ResumeVisibility {
  PUBLIC
  UNLISTED
  WITHDRAWN
}

enum ResumeTheme {
  RESUME
  MINIMAL
}

enum ReportCategory {
  IMPERSONATION
  PRIVACY
  HARASSMENT
  OTHER
}

enum ReportState {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

/// A non-numeric, tag-only record left after a party run.
enum TemperatureFeedbackStatus {
  PUBLISHED
  WITHDRAWN
}

/// Whether the post author is recruiting members or looking for a party to join.
enum PartyPostKind {
  RECRUITING
  LOOKING
}

/// A closed post remains auditable to its owner but is never publicly discoverable.
enum PartyPostStatus {
  OPEN
  CLOSED
}

/// Only the post owner can move an application out of the pending state.
enum PartyApplicationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum PartyTargetCadence {
  WEEKLY
  MONTHLY
}

/// A stable character identity. Mutable character properties belong to snapshots.
model Character {
  id                           String                        @id @default(cuid())
  ocid                         String                        @unique @db.VarChar(128)
  name                         String                        @db.VarChar(64)
  worldName                    String?                       @db.VarChar(64)
  /// Highest raw combat power the service has observed for this character.
  peakCombatPower              BigInt?
  peakCombatPowerAt            DateTime?                     @db.Timestamptz(3)
  firstSeenAt                  DateTime                      @default(now()) @db.Timestamptz(3)
  lastSeenAt                   DateTime                      @default(now()) @db.Timestamptz(3)
  createdAt                    DateTime                      @default(now()) @db.Timestamptz(3)
  updatedAt                    DateTime                      @updatedAt @db.Timestamptz(3)
  snapshots                    ProfileSnapshot[]
  resumes                      Resume[]
  guildObservations            GuildObservation[]
  temperatureSurveyInvitations TemperatureSurveyInvitation[]
  temperatureSurveyResponses   TemperatureSurveyResponse[]

  @@index([name])
  @@index([lastSeenAt])
}

/// An immutable, normalized response from either the live or mock character provider.
model ProfileSnapshot {
  id                String             @id @default(cuid())
  characterId       String
  fetchedAt         DateTime           @default(now()) @db.Timestamptz(3)
  /// Source game date is deliberately kept as the provider's YYYY-MM-DD/string value.
  sourceDate        String?            @db.VarChar(32)
  provider          SnapshotProvider
  normalized        Json
  /// Limited/encrypted raw payload only; it is never returned by public handlers.
  rawPayload        Json?
  rawAvailability   Json
  freshness         SnapshotFreshness  @default(FRESH)
  freshUntil        DateTime           @db.Timestamptz(3)
  expiresAt         DateTime           @db.Timestamptz(3)
  contentHash       String             @db.VarChar(64)
  createdAt         DateTime           @default(now()) @db.Timestamptz(3)
  character         Character          @relation(fields: [characterId], references: [id], onDelete: Cascade)
  resumeVersions    ResumeVersion[]
  calculatedMetrics CalculatedMetric[]
  guildObservations GuildObservation[]

  @@index([characterId, fetchedAt])
  @@index([freshness, expiresAt])
  @@index([contentHash])
}

/// A public resume has one mutable pointer to its latest immutable version.
model Resume {
  id                        String                @id @default(cuid())
  slug                      String                @unique @db.VarChar(96)
  characterId               String
  currentVersionId          String?               @unique
  visibility                ResumeVisibility      @default(PUBLIC)
  /// SHA-256 (or stronger) hash only; the plaintext edit token is never persisted.
  editTokenHash             String                @db.VarChar(128)
  createdAt                 DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt                 DateTime              @updatedAt @db.Timestamptz(3)
  withdrawnAt               DateTime?             @db.Timestamptz(3)
  character                 Character             @relation(fields: [characterId], references: [id], onDelete: Cascade)
  currentVersion            ResumeVersion?        @relation("CurrentResumeVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions                  ResumeVersion[]       @relation("ResumeVersions")
  reports                   Report[]
  temperatureFeedbacksGiven TemperatureFeedback[] @relation("TemperatureFeedbackReviewerResume")

  @@index([characterId])
  @@index([visibility, updatedAt])
}

/// Published content is versioned rather than overwritten, preserving image/verifier integrity.
model ResumeVersion {
  id                     String                  @id @default(cuid())
  resumeId               String
  snapshotId             String
  userInput              Json
  theme                  ResumeTheme             @default(RESUME)
  contentHash            String                  @db.VarChar(64)
  versionNumber          Int
  publishedAt            DateTime                @default(now()) @db.Timestamptz(3)
  createdAt              DateTime                @default(now()) @db.Timestamptz(3)
  resume                 Resume                  @relation("ResumeVersions", fields: [resumeId], references: [id], onDelete: Cascade)
  snapshot               ProfileSnapshot         @relation(fields: [snapshotId], references: [id])
  currentFor             Resume?                 @relation("CurrentResumeVersion")
  calculatedMetrics      CalculatedMetric[]
  temperatureInvitations TemperatureInvitation[] @relation("TemperatureInvitationTargetVersion")
  temperatureFeedbacks   TemperatureFeedback[]   @relation("TemperatureFeedbackTargetVersion")
  partyPosts             PartyPost[]             @relation("PartyPostOwnerVersion")
  partyApplications      PartyApplication[]      @relation("PartyApplicationResumeVersion")

  @@unique([resumeId, versionNumber], name: "resumeId_versionNumber")
  @@unique([id, resumeId], name: "id_resumeId")
  @@index([snapshotId])
  @@index([contentHash])
}

/// Auditable service-calculated values. User-entered values stay in ResumeVersion.userInput.
model CalculatedMetric {
  id               String          @id @default(cuid())
  snapshotId       String
  resumeVersionId  String?
  key              String          @db.VarChar(96)
  value            String          @db.VarChar(128)
  unit             String?         @db.VarChar(32)
  provenance       DataProvenance  @default(SERVICE_CALCULATED)
  algorithmName    String          @db.VarChar(128)
  algorithmVersion String          @db.VarChar(64)
  inputs           Json
  includedFields   Json
  excludedFields   Json
  disclaimer       String          @db.Text
  calculatedAt     DateTime        @default(now()) @db.Timestamptz(3)
  snapshot         ProfileSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  resumeVersion    ResumeVersion?  @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)

  @@unique([resumeVersionId, key], name: "resumeVersionId_key")
  @@index([snapshotId])
}

/// Service observations are intervals, not asserted guild join/leave dates.
model GuildObservation {
  id               String          @id @default(cuid())
  characterId      String
  guildName        String?         @db.VarChar(64)
  provenance       DataProvenance  @default(SERVICE_OBSERVED)
  observedFrom     DateTime        @db.Timestamptz(3)
  lastObservedAt   DateTime        @db.Timestamptz(3)
  observedTo       DateTime?       @db.Timestamptz(3)
  sourceSnapshotId String
  createdAt        DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime        @updatedAt @db.Timestamptz(3)
  character        Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  sourceSnapshot   ProfileSnapshot @relation(fields: [sourceSnapshotId], references: [id])

  @@index([characterId, observedTo])
  @@index([sourceSnapshotId])
}

/// Report records are deliberately modelled without an administrator UI in the MVP.
model Report {
  id        String         @id @default(cuid())
  resumeId  String
  category  ReportCategory
  detail    String?        @db.VarChar(1000)
  state     ReportState    @default(OPEN)
  createdAt DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt DateTime       @updatedAt @db.Timestamptz(3)
  resume    Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId, state])
  @@index([state, createdAt])
}

/// One-time, expiring proof that a party member may leave a tag-only record.
/// Only the hash is stored; the raw token is present solely in the issued URL.
model TemperatureInvitation {
  id              String               @id @default(cuid())
  resumeId        String
  resumeVersionId String
  tokenHash       String               @unique @db.VarChar(128)
  expiresAt       DateTime             @db.Timestamptz(3)
  usedAt          DateTime?            @db.Timestamptz(3)
  revokedAt       DateTime?            @db.Timestamptz(3)
  createdAt       DateTime             @default(now()) @db.Timestamptz(3)
  resumeVersion   ResumeVersion        @relation("TemperatureInvitationTargetVersion", fields: [resumeVersionId, resumeId], references: [id, resumeId], onDelete: Cascade)
  feedback        TemperatureFeedback?

  @@index([resumeId, resumeVersionId, expiresAt])
  @@index([expiresAt])
}

/// The resulting non-numeric, non-anonymous positive feedback.
model TemperatureFeedback {
  id                String                    @id @default(cuid())
  resumeId          String
  resumeVersionId   String
  invitationId      String                    @unique
  reviewerResumeId  String
  reviewerSlug      String                    @db.VarChar(96)
  reviewerOcid      String                    @db.VarChar(128)
  reviewerName      String                    @db.VarChar(64)
  reviewerWorldName String?                   @db.VarChar(64)
  reviewerClassName String?                   @db.VarChar(64)
  tags              Json
  status            TemperatureFeedbackStatus @default(PUBLISHED)
  createdAt         DateTime                  @default(now()) @db.Timestamptz(3)
  withdrawnAt       DateTime?                 @db.Timestamptz(3)
  resumeVersion     ResumeVersion             @relation("TemperatureFeedbackTargetVersion", fields: [resumeVersionId, resumeId], references: [id, resumeId], onDelete: Cascade)
  invitation        TemperatureInvitation     @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  reviewerResume    Resume                    @relation("TemperatureFeedbackReviewerResume", fields: [reviewerResumeId], references: [id], onDelete: Cascade)

  @@unique([resumeId, reviewerOcid], name: "resumeId_reviewerOcid")
  @@index([resumeVersionId, status, createdAt])
  @@index([reviewerResumeId])
}

/// Anonymous one-time survey invite, scoped to the stable Character identity.
/// The raw token is only delivered in a URL fragment; this table stores its hash.
model TemperatureSurveyInvitation {
  id          String                     @id @default(cuid())
  characterId String
  tokenHash   String                     @unique @db.VarChar(128)
  expiresAt   DateTime                   @db.Timestamptz(3)
  usedAt      DateTime?                  @db.Timestamptz(3)
  revokedAt   DateTime?                  @db.Timestamptz(3)
  createdAt   DateTime                   @default(now()) @db.Timestamptz(3)
  character   Character                  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  response    TemperatureSurveyResponse?

  @@index([characterId, expiresAt])
  @@index([expiresAt])
}

/// Anonymous survey answers persist at the character level across resume copies.
/// No reviewer identity, resume, OCID, name, or contact field is stored here.
model TemperatureSurveyResponse {
  id               String                      @id @default(cuid())
  characterId      String
  invitationId     String                      @unique
  experienceScore  Int
  proficiencyScore Int
  punctualityScore Int
  totalDelta       Int
  createdAt        DateTime                    @default(now()) @db.Timestamptz(3)
  character        Character                   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  invitation       TemperatureSurveyInvitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([characterId, createdAt])
}

/// A structured in-site party listing pinned to one immutable, currently public resume version.
model PartyPost {
  id                   String          @id @default(cuid())
  slug                 String          @unique @db.VarChar(96)
  kind                 PartyPostKind
  status               PartyPostStatus @default(OPEN)
  ownerResumeId        String
  ownerResumeSlug      String          @db.VarChar(96)
  ownerResumeVersionId String
  ownerCharacterOcid   String          @db.VarChar(128)
  expiresAt            DateTime        @db.Timestamptz(3)
  createdAt            DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime        @updatedAt @db.Timestamptz(3)
  closedAt             DateTime?       @db.Timestamptz(3)
  ownerResumeVersion   ResumeVersion   @relation("PartyPostOwnerVersion", fields: [ownerResumeVersionId, ownerResumeId], references: [id, resumeId], onDelete: Cascade)
  targets              PartyPostTarget[]
  applications         PartyApplication[]

  @@index([status, expiresAt, createdAt])
  @@index([ownerResumeId, status])
}

/// Immutable, normalized copies of the selected boss targets from a post's resume version.
model PartyPostTarget {
  id                   String              @id @default(cuid())
  postId               String
  sourceBossKey        String              @db.VarChar(128)
  sourceBossId         String?             @db.VarChar(96)
  bossName             String              @db.VarChar(96)
  cadence              PartyTargetCadence?
  bossMultiplierPercent String?            @db.VarChar(40)
  maxPartySize         Int
  sortOrder            Int
  post                 PartyPost           @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, sourceBossKey])
  @@index([cadence, bossName])
  @@index([postId, sortOrder])
}

/// A resume-backed application. It stores no edit token, contact field, or temperature response detail.
model PartyApplication {
  id                       String                 @id @default(cuid())
  postId                   String
  applicantResumeId        String
  applicantResumeSlug      String                 @db.VarChar(96)
  applicantResumeVersionId String
  applicantCharacterOcid   String                 @db.VarChar(128)
  status                   PartyApplicationStatus @default(PENDING)
  message                  String?                @db.VarChar(240)
  createdAt                DateTime               @default(now()) @db.Timestamptz(3)
  decidedAt                DateTime?              @db.Timestamptz(3)
  post                     PartyPost              @relation(fields: [postId], references: [id], onDelete: Cascade)
  applicantResumeVersion   ResumeVersion          @relation("PartyApplicationResumeVersion", fields: [applicantResumeVersionId, applicantResumeId], references: [id, resumeId], onDelete: Cascade)

  @@unique([postId, applicantCharacterOcid])
  @@index([postId, status, createdAt])
  @@index([applicantResumeId, status])
}
